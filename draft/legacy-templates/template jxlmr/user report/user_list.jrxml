			<style backcolor="#0000FF"/>
		</conditionalStyle>
	</style>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT au.first_name+''+au.last_name as username,
au.email,
au.created_date,
aua.authority_name as role,
ap.img as logo,
CASE
	WHEN au.activated =1 THEN 'Active'
	ELSE 'Inactive'
END AS status
FROM adm_user au
JOIN adm_user_authority aua ON aua.user_id =au.id
JOIN adm_user_project aup ON aup.user_id =au.id 
JOIN adm_project ap ON ap.id=aup.project_id
WHERE au.customer_id IS NULL
and aup.project_id = $P{project_id}]]>
	</queryString>
