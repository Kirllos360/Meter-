	<parameter name="customer_id" class="java.lang.String"/>
	<parameter name="date_start" class="java.lang.String"/>
	<parameter name="date_end" class="java.lang.String"/>
	<parameter name="unitNumber" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  customer.code customer_code,
  customer.id customer_id,
  meter.id meter_id,
  customer.name_en customer_name,
  customer.name_ar,
  unit.additional_info,
  unit.unit_no as 'unit_no',
  meter.serial meter_serial,
  meter.type meter_service,
  (
    select SUM(total_cons)
	from monthly_reading
	where meter.id = monthly_reading.meter_id
	and (monthly_reading.consumption_month BETWEEN $P{date_start} AND $P{date_end})
  ) cons_kwh,
  (
    select SUM(monthly_reading.total_cons)
	from monthly_reading
	where meter.id = monthly_reading.meter_id
    and monthly_reading.invoice_id is null
	and monthly_reading.status <> 'NEW'
	and (monthly_reading.consumption_month BETWEEN $P{date_start} AND $P{date_end} )
  ) not_invoice_amt,
  (
    select SUM(invoice.paid_amt)
	from invoice
	where meter.id = invoice.meter_id
	and (invoice.counsumption_month BETWEEN $P{date_start} AND $P{date_end} )
  ) as paid_invoices_amt,
  (
    select SUM(invoice.open_amt)
	from invoice
	where meter.id = invoice.meter_id
	and (invoice.counsumption_month BETWEEN $P{date_start} AND $P{date_end} )
  ) as open_invoices_amt,
  (
    select SUM(invoice.total_amt)
	from invoice
	where meter.id = invoice.meter_id
	and (invoice.counsumption_month BETWEEN $P{date_start} AND $P{date_end} )
  ) as invoices_amt,
  (
    select SUM(payment.total_amt)
    from payment
    where meter.id = payment.meter_id
    and (payment.created_date BETWEEN $P{date_start} AND $P{date_end} )
  ) as payments_amt
FROM
  customer INNER JOIN meter ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
WHERE
  1 = 1
  and (customer.id = $P{customer_id} OR $P{customer_id} IS NULL)
  and (unit.unit_no = $P{unitNumber} OR $P{unitNumber} IS NULL)
  and (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  and meter.project_id = $P{project_id}]]>
	</queryString>
	<field name="customer_code" class="java.lang.String"/>
	<field name="customer_id" class="java.lang.Long"/>
	<field name="meter_id" class="java.lang.Long"/>
	<field name="customer_name" class="java.lang.String"/>
	<field name="unit_no" class="java.lang.String"/>
	<field name="meter_serial" class="java.lang.String"/>
	<field name="meter_service" class="java.lang.String"/>
	<field name="cons_kwh" class="java.lang.Double"/>
	<field name="not_invoice_amt" class="java.lang.Double"/>
	<field name="paid_invoices_amt" class="java.lang.Long"/>
	<field name="open_invoices_amt" class="java.lang.Long"/>
	<field name="invoices_amt" class="java.lang.Long"/>
	<field name="payments_amt" class="java.lang.Long"/>
	<field name="name_ar" class="java.lang.String"/>
	<field name="additional_info" class="java.lang.String"/>
	<sortField name="meter_id"/>
	<variable name="not_invoiced_SUM" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{not_invoice_amt}]]></variableExpression>
	</variable>
	<variable name="total_invoices_SUM" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{invoices_amt}]]></variableExpression>
	</variable>
	<variable name="total_payments_SUM" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{payments_amt}]]></variableExpression>
	</variable>
