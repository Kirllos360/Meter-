	<subDataset name="Table Dataset 1" uuid="624af762-9ce3-4c7a-98e4-7f50ddbaf01b"/>
	<parameter name="customer_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_code_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{customer_code} == null  ? "1=1" : "lower(customer.customer_code) like lower('%" + $P{customer_code} + "%')"]]></defaultValueExpression>
	</parameter>
	<parameter name="organization_ids" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="organization_ids_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{organization_ids} == null  ? "1=1" : "organization_portal.organizationid in (" + $P{organization_ids} + ")"]]></defaultValueExpression>
	</parameter>
	<parameter name="date_start" class="java.lang.String">
		<defaultValueExpression><![CDATA["2014-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="date_end" class="java.lang.String">
		<defaultValueExpression><![CDATA["2014-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="database_type" class="java.lang.String">
		<defaultValueExpression><![CDATA["SQL"]]></defaultValueExpression>
	</parameter>
	<parameter name="date_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[($P{database_type}.equalsIgnoreCase("ORCL")) ? "to_date(to_char(CHARGE_DATE,'yyyy-MM-dd'),'yyyy-MM-dd')>=to_date('"+$P{date_start}+"','yyyy-MM-dd') and to_date(to_char(CHARGE_DATE,'yyyy-MM-dd'),'yyyy-MM-dd')<=to_date('"+$P{date_end}+"','yyyy-MM-dd') " : " cast(CHARGE_DATE as date)>=cast('"+$P{date_start}+"' as date) and cast(CHARGE_DATE as date)<=cast('"+$P{date_end}+"' as date)"]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_name_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{customer_name} == null  ? "1=1" : ($P{database_type} == "ORCL" ? "lower(customer.customer_name) like lower('%" + $P{customer_name} + "%')" : "lower(customer.customer_name) like lower(N'%" + $P{customer_name} + "%')")]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_serial_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{meter_serial} == null  ? "1=1" : "meters.meter_serial like '%" + $P{meter_serial} + "%'"]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_serial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="location_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="location_name_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{location_name} == null  ? "1=1" : ($P{database_type} == "ORCL" ? "lower(location.full_location_name) like lower('%" + $P{location_name} + "%')" : "lower(location.full_location_name) like lower(N'%" + $P{location_name} + "%')")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select customer.customer_code,
customer.customer_name, billing_account.name, meters.meter_serial,
 prepaid_transaction_details.amount,
 prepaid_transaction_details.charge_date,
 lk_charge_type.charge_type_name,
 prepaid_transaction_details.consumption_current_value,
  prepaid_transaction_details.consumption_last_value,
  prepaid_transaction_details.current_balance,
organization_portal.name ORG_NAME
 from
prepaid_transaction_details ,
 customer, billing_account, meters,lk_charge_type, organization_portal, location
 where prepaid_transaction_details.customer_id=customer.customer_id
 and billing_account.customer_id=customer.customer_id
 and prepaid_transaction_details.billing_account_id=billing_account.billing_account_id
and customer.organization_id=organization_portal.organizationid
and meters.meter_id=prepaid_transaction_details.meter_id
and meters.location_id=location.location_id
and lk_charge_type.charge_type_id=prepaid_transaction_details.charge_type_id
and $P!{date_where} and $P!{customer_code_where} and $P!{meter_serial_where} and $P!{organization_ids_where} and $P!{location_name_where}and $P!{customer_name_where}
order by charge_date asc]]>
	</queryString>
