	<parameter name="project_id" class="java.lang.Integer"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="customer_id" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select
  (select project_title_ar from adm_project where id = m.project_id) project_title,
  (select address_ar from adm_project where id = m.project_id) address,
  (select img from adm_project where id = m.project_id) logo,
  c.id,
  c.name_ar,
  c.name_en,
  c.status,
  m.payment_type customer_type,
  c.mobile,
  c.email,
  m.serial,
  m.[type] meter_type,
  m.activation_date,
  l.additional_info,
  l.unit_no,
  '' as address_ar,
  '' as address_en,
  l.city,
  m.last_reading_date,
  isnull(m.balance,0) balance,
  (select isnull(sum(mr.total_amount),0) from monthly_reading mr where mr.meter_id =m.id and mr.invoice_id is null) not_invoiced,
  (select isnull(sum(i.open_amt),0) from invoice i where i.meter_id =m.id and i.status = 'ACTIVE') open_invoices
from
  customer c,
  meter m,
  unit l
where
  c.id = m.customer_id
  and m.unit_id = l.id
  and m.payment_type = 'Prepaid'
  and m.relay_status = 'DISCONNECTED'
  and m.project_id = $P{project_id}
  and (c.id = $P{customer_id} OR $P{customer_id} IS NULL)
  and (c.name_en = $P{customer_name} OR $P{customer_name} IS NULL)]]>
	</queryString>
