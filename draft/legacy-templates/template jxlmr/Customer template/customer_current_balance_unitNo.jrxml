	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="taqa_test"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="reading_since" class="java.lang.Integer"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = meter.project_id) project_title,
  (select address_ar from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  customer.id AS customer_id,
  customer.name_en AS customer_name,
  customer.name_ar AS customer_name_ar,
  customer.phone AS primary_Phone ,
  customer.mobile AS secondary_phone,
  meter.payment_type as customer_type,
  unit.unit_no AS unit_no,
  unit.additional_info,
  meter.initial_balance AS initial_balance,
  meter.serial AS meter_serial,
  meter.relay_status as relay_status,
  ISNULL(meter.balance,0) -
  (
    SELECT ISNULL(SUM(invoice.open_amt),0)
    from invoice WHERE invoice.status != 'DELETED' AND invoice.meter_id = meter.id
  ) - (
    SELECT ISNULL(SUM(monthly_reading.total_amount),0)
	from monthly_reading WHERE monthly_reading.meter_id = meter.id
    and monthly_reading.invoice_id is null
	and monthly_reading.status <> 'NEW'
  ) as current_balance,
  meter.last_reading_date as last_reading_date,
  meter.type AS service_name
FROM
  meter
  INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
WHERE
  1 = 1
  AND (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  AND (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  AND (unit.unit_no = $P{unit_number}  OR $P{unit_number} IS NULL)
  AND (unit.city = $P{village}  OR $P{village} IS NULL)
  AND (DATEADD(day, ISNULL($P{reading_since}, 0), meter.last_reading_date) < GETDATE()  OR $P{reading_since} IS NULL)
  AND meter.project_id = $P{project_id}
ORDER BY
  customer.id,
  meter.id]]>
	</queryString>
