	</style>
	<parameter name="customer_id" class="java.lang.String"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[select
  (select project_title_ar from adm_project where id = meter.project_id) project_title,
  (select address_ar from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  customer.id AS customer_code,
  customer.name_en AS customer_name,
  customer.name_ar AS customer_name_ar,
  customer.phone AS primary_phone,
  meter.activation_date AS activation_date,
  customer.created_date AS contract_date,
  customer.mobile AS secondary_phone,
  meter.serial AS meter_serial,
  unit.unit_no AS unit_number,
  meter.status AS meter_status,
  meter.type AS service_name,
  unit.additional_info
FROM
  meter
  INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
WHERE
  (customer.id = $P{customer_id} OR $P{customer_id} IS NULL)
  and (customer.name_en = $P{customer_name} OR $P{customer_name} IS NULL)
  and meter.project_id = $P{project_id}]]>
	</queryString>
