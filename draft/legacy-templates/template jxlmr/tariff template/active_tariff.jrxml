	<queryString>
		<![CDATA[select
  (select project_title_ar from adm_project where id = 1) project_title,
  (select address_ar from adm_project where id = 1) address,
  (select img from adm_project where id = 1) logo,
  id,
  start_date,
  service_type as service,
  mode,
  name_ar as name,
  status,
  0 as flat_rate
from
  tariff
where
  status = 'ACTIVE']]>
	</queryString>
	<field name="project_title" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
