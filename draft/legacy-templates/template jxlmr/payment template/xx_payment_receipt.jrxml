			<style mode="Opaque" backcolor="#F0EFEF"/>
		</conditionalStyle>
	</style>
	<parameter name="paymentId" class="java.lang.Long"/>
	<queryString>
		<![CDATA[select
  (select general_settings_value from general_settings where general_settings_key = 'project_title') project_title,
  (select general_settings_value from general_settings where general_settings_key = 'project_title_ar') project_title_ar,
  (select general_settings_value from general_settings where general_settings_key = 'project_subtitle') project_subtitle,
  (select general_settings_value from general_settings where general_settings_key = 'project_subtitle_ar') project_subtitle_ar,
  (select general_settings_value from general_settings where general_settings_key = 'site_name') site_name,
  (select general_settings_value from general_settings where general_settings_key = 'site_name_ar') site_name_ar,
  p.id,
  p.status,
  c.id customer_id,
  l.unit_no,
  c.name_ar,
  c.name_en,
--  SUBSTRING( ( SELECT ' - ' + name_ar AS [text()] FROM dbo.[contact_person] WHERE customer_id = p.customer_id FOR XML PATH ('') ), 2, 1000) names_ar,
--  SUBSTRING( ( SELECT ' - ' + name_en AS [text()] FROM dbo.[contact_person] WHERE customer_id = p.customer_id FOR XML PATH ('') ), 2, 1000) names_en,
  p.type,
  p.total_amt,
p.advanced_amt ,
p.settlement_amount,
  p.receipt_no,
  p.payment_date,
  c.name_en,
  c.name_ar,
  m.serial,
  m.[type] meter_type,
  p.created_by,
  p.cheque_number,
  p.bank_name,
  p.balance_before,
  p.balance_after,
  p.last_reading_date
from
  payment p,
  customer c,
  meter m,
  location l
where
  p.id = $P{paymentId}
  and p.customer_id = c.id
  and m.location_id = l.id
  and m.customer_id = c.id
  and m.id = p.meter_id]]>
	</queryString>
