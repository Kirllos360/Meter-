	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="taqa_test"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="start_date" class="java.lang.String"/>
	<parameter name="end_date" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[select
  (select project_title_ar from adm_project where id = m.project_id) project_title,
  (select address_ar from adm_project where id = m.project_id) address,
  (select img from adm_project where id = m.project_id) logo,
  c.name_en,
  c.name_ar,
  m.serial,
  m.type,
  l.unit_no,
  l.additional_info,
  l.city,
  X.action,
  X.action_date,
  X.amount,
  X.number,
  X.status
from
  customer c
  inner join meter m on m.customer_id = c.id
  inner join unit l on l.id = m.unit_id
  inner join
  (
    select
     'Invoice' as action,
     i.counsumption_month action_date,
     i.number number,
     i.total_amt amount,
     i.meter_id,
     i.status
    from
     invoice i
    union all
    select
     'Payment' as action,
     p.payment_date action_date,
     p.receipt_no number,
     p.total_amt amount,
	 p.meter_id,
     p.status
    from
     payment p
  ) X on m.id = X.meter_id
where
  1 = 1
  and convert(date, X.action_date) >= $P{start_date}
  and convert(date, X.action_date) <= $P{end_date}
  and (m.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  and (m.type = $P{meter_type} OR $P{meter_type} IS NULL)
  and (l.unit_no = $P{unit_number} OR $P{unit_number} IS NULL)
  and (l.city = $P{village} OR $P{village} IS NULL)
  and m.project_id = $P{project_id}
order by
  c.id,
  X.action_date]]>
	</queryString>
