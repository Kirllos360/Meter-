	<parameter name="start_date" class="java.lang.String"/>
	<parameter name="end_date" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  nq.id,
  nq.created_date,
  nq.text,
  nq.email,
  nq.mobile_number,
  nq.mode mode,
  nq.customer_id,
  nq.meter_id,
  m.serial,
  c.name_ar,
  c.name_en
FROM
  notifications_queue nq
JOIN meter m ON m.id = nq.meter_id
JOIN customer c ON c.id = nq.customer_id
WHERE
  m.id = nq.meter_id
  AND nq.is_sent = 0
  AND nq.created_date BETWEEN $P{start_date} AND $P{end_date}
  AND m.project_id = $P{project_id}]]>
	</queryString>
