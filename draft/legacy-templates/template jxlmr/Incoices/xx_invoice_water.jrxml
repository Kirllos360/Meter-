<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="elec_invoice" pageWidth="421" pageHeight="297" orientation="Landscape" columnWidth="413" leftMargin="4" rightMargin="4" topMargin="5" bottomMargin="5" uuid="b3aae808-6eeb-4617-b9a8-226c81ef6df3">
	<property name="ireport.zoom" value="2.0"/>
