	<property name="ireport.y" value="5"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="invoiceId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
  i.id,
  i.[number],
  i.status,
  i.issue_date,
  i.counsumption_month,
  i.counsumption_value,
  i.start_reading,
  i.end_reading,
  i.meter_serial,
  i.customer_id,
  t.name,
  i.total_amt,
  c.name_ar,
  l.unit_no,
  l.address_ar,
  l.city,
  i.balance_after,
  i.balance_before,
  (select amount from invoice_details id where invoice_id = $P{invoiceId} and name = 'Cosnumption') 'Cons',
  (select amount from invoice_details id where invoice_id = $P{invoiceId} and name = 'Admin Fees') 'Admin',
  (select amount from invoice_details id where invoice_id = $P{invoiceId} and name = 'Sewage') 'Sewage'
from
  invoice i,
  customer c,
  meter m,
  tariff t,
  location l
where
  i.customer_id = c.id
  and i.meter_id = m.id
  and m.tariff_id = t.id
  and m.location_id = l.id
  and i.id = $P{invoiceId}]]>
	</queryString>
