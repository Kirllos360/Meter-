<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Invoices" pageWidth="1221" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="1181" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="3cd41ce5-13e0-47c4-a5fa-76d5f4b5d781">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="193"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Billing"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.1" value="title"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.3" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.2" value="Summary"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.4" value="pageFooter"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.keep.first.band.1" value="columnHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.5" value="groupHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.group.5" value="Org Group"/>
	<style name="alternateStyle" mode="Transparent" backcolor="#FFFFFF" fontName="DejaVu Sans">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
			<style backcolor="#0000FF"/>
		</conditionalStyle>
	</style>
	<parameter name="date_start" class="java.lang.String"/>
	<parameter name="date_end" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="status" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="service_type" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="tariff_id" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = X.project_id) project_title,
  (select address_ar from adm_project where id = X.project_id) address,
  (select img from adm_project where id = X.project_id) logo,
  i.id,
  i.[number],
  i.status,
  convert(varchar, i.issue_date, 23) issue_date,
  FORMAT (i.counsumption_month, 'MMM-yy') counsumption_month,
  i.meter_serial,
  X.unit_no,
  cast (i.total_amt / 1000.00 as MONEY) amount,
  cast (i.paid_amt / 1000.00 as MONEY) paid_amt,
  cast (i.open_amt / 1000.00 as MONEY) open_amt,
  i.[type] service,
  i.total_consumption,
  (select top 1 id.start_reading from invoice_details id where id.invoice_id = i.id) 'start_reading',
  (select top 1 id.end_reading from invoice_details id where id.invoice_id = i.id) 'end_reading',
  X.customer_name,
  (select sum(amount) from invoice_details id where invoice_id = i.id and charge_group = 'CONSUMPTION') 'consumption_fees',
  (select sum(amount) from invoice_details id where invoice_id = i.id and charge_group = 'FEES') 'radio_fees',
  (select sum(amount) from invoice_details id where invoice_id = i.id and charge_group = 'TAX') 'stamp_tax',
  (select sum(amount) from invoice_details id where invoice_id = i.id and charge_group = 'OTHER') 'other_fees',
  (select sum(amount) from invoice_details id where invoice_id = i.id and charge_group = 'CUSTOMER_SERVICE') 'customer_service'
FROM
  invoice i
  inner join
  (
    select unit_no, meter.id as meter_id, meter.project_id as project_id, customer.name_ar as customer_name
    from unit
	inner join meter on meter.unit_id = unit.id
	inner join customer on meter.customer_id = customer.id
	where
	meter.tariff_id = $P{tariff_id} OR $P{tariff_id} IS NULL
  ) AS X ON i.meter_id = X.meter_id
 where
  CONVERT(DATE, i.counsumption_month ) >= $P{date_start}
  and CONVERT(DATE, i.counsumption_month ) <= $P{date_end}
  and (X.unit_no = $P{unit_number} OR $P{unit_number} IS NULL)
  and (i.status = $P{status}  OR $P{status} IS NULL)
  and (i.type = $P{service_type}  OR $P{service_type} IS NULL)]]>
	</queryString>
	<field name="project_title" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
	<field name="logo" class="java.lang.String"/>
	<field name="id" class="java.lang.Long"/>
	<field name="number" class="java.lang.String"/>
	<field name="status" class="java.lang.String"/>
	<field name="issue_date" class="java.lang.String"/>
	<field name="counsumption_month" class="java.lang.String"/>
	<field name="meter_serial" class="java.lang.String"/>
	<field name="unit_no" class="java.lang.String"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="paid_amt" class="java.math.BigDecimal"/>
	<field name="open_amt" class="java.math.BigDecimal"/>
	<field name="service" class="java.lang.String"/>
	<field name="total_consumption" class="java.lang.Double"/>
	<field name="start_reading" class="java.lang.Double"/>
	<field name="end_reading" class="java.lang.Double"/>
	<field name="customer_name" class="java.lang.String"/>
	<field name="consumption_fees" class="java.lang.Long"/>
	<field name="radio_fees" class="java.lang.Long"/>
	<field name="stamp_tax" class="java.lang.Long"/>
	<field name="other_fees" class="java.lang.Long"/>
	<field name="customer_service" class="java.lang.Long"/>
	<variable name="totalPaid" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{paid_amt}]]></variableExpression>
	</variable>
	<variable name="invoiceAmount" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{amount}]]></variableExpression>
	</variable>
	<variable name="remainingAmount" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{open_amt}]]></variableExpression>
	</variable>
