<!-- Created with Jaspersoft Studio version last-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Canceled Invoices" pageWidth="1350" pageHeight="842" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="1310" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="3cd41ce5-13e0-47c4-a5fa-76d5f4b5d781">
	<style name="alternateStyle" mode="Transparent" backcolor="#FFFFFF" fontName="DejaVu Sans">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
			<style backcolor="#0000FF"/>
		</conditionalStyle>
	</style>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="bill_cycle" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  (select project_title_en from adm_project where id = meter.project_id) project_title,
  (select address_en from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  customer.id,
  customer.name_en CUSTOMER_NAME,
  customer.name_ar as name_ar,
  customer.phone AS primary_phone,
  invoice.total_amt  AS TOTAL_AMOUNT,
  invoice.cancelation_reason  AS CANCELATION_REASON,
  invoice.[number] invoice_no,
  invoice.total_consumption AS CONSUMPTION,
  unit.unit_no AS unitName,
  0 AS start_reading,
  0 AS current_reading,
  invoice.issue_date AS issue_date,
  invoice.counsumption_month AS BC_DATE,
  meter.serial AS METER_SERIAL,
  meter.type SERVICE_NAME
FROM
  meter INNER JOIN invoice ON invoice.meter_id = meter.id
  INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id ------------------------
WHERE
  (invoice.status = 'INACTIVE' OR invoice.status = 'DELETED')
  AND (unit.city = $P{village}  OR $P{village} IS NULL)
  AND (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  AND (invoice.counsumption_month = $P{bill_cycle} OR $P{bill_cycle} IS NULL)
  AND (customer.name_en like $P{customer_name} OR $P{customer_name} IS NULL )
  AND (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  AND (unit.unit_no = $P{unit_number} OR $P{unit_number} IS NULL)
  AND meter.project_id = $P{project_id}]]>
	</queryString>
