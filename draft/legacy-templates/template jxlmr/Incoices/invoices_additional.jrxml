	<parameter name="date_start" class="java.lang.String"/>
	<parameter name="date_end" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="status" class="java.lang.String"/>
	<parameter name="service_type" class="java.lang.String"/>
	<parameter name="tariff_id" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = X.project_id) project_title,
  (select address_ar from adm_project where id = X.project_id) address,
  (select img from adm_project where id = X.project_id) logo,
  i.id,
  i.[number],
  i.status,
  convert(varchar, i.issue_date, 23) issue_date,
  FORMAT (i.counsumption_month, 'MMM-yy') counsumption_month,
  i.meter_serial,
  X.unit_no,
  X.additional_info ,
  CAST (i.total_amt / 1000.00 as MONEY) amount,
  CAST (i.paid_amt / 1000.00 as MONEY) paid_amt,
  CAST (i.open_amt / 1000.00 as MONEY) open_amt,
  i.[type] service
FROM
  invoice i
  inner join
  (
    select unit_no,additional_info, meter.id as meter_id, meter.project_id as project_id
    from unit
	inner join meter on meter.unit_id = unit.id
	inner join customer on meter.customer_id = customer.id
	where meter.tariff_id = $P{tariff_id} OR $P{tariff_id} IS NULL
  ) AS X ON i.meter_id = X.meter_id
WHERE
  CONVERT(DATE, i.counsumption_month ) >= $P{date_start}
  and CONVERT(DATE, i.counsumption_month ) <= $P{date_end}
  and (X.unit_no = $P{unit_number} OR $P{unit_number} IS NULL)
  and (i.status = $P{status}  OR $P{status} IS NULL)
  and (i.type = $P{service_type}  OR $P{service_type} IS NULL)
  and X.project_id = $P{project_id}]]>
	</queryString>
