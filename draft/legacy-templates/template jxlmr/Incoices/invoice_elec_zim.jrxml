	<subDataset name="invoice_details" uuid="ef4d6ec1-7cf0-4d4b-8b94-d3451e8a2461">
		<parameter name="invoiceId" class="java.lang.Long"/>
		<parameter name="invoiceAmt" class="java.lang.Long"/>
		<queryString language="SQL">
			<![CDATA[select
  name as charge_name,
  amount as charge_amount,
  start_reading,
  end_reading,
  consumption_value,
  tc.flat_rate
from
  invoice_details id
  left outer join tariff_charges tc on id.tariff_charge_id = tc.id
where
  invoice_id = $P{invoiceId}]]>
		</queryString>
		<field name="charge_name" class="java.lang.String"/>
		<field name="charge_amount" class="java.lang.Long"/>
		<field name="start_reading" class="java.lang.Double"/>
		<field name="end_reading" class="java.lang.Double"/>
		<field name="consumption_value" class="java.lang.Double"/>
		<field name="flat_rate" class="java.lang.Long"/>
	</subDataset>
	<parameter name="invoiceId" class="java.lang.Long"/>
	<queryString>
		<![CDATA[select
  i.id as invoice_id,
  c.code as customer_code,
  i.number as invoice_number,
  m.serial,
  t.name_en as tariff_name,
  i.counsumption_month,
  DATEADD(month, 1, i.counsumption_month) as due_date,
  i.total_amt,
  i.total_consumption,
  u.unit_no
from
  invoice i,
  meter m,
  customer c,
  tariff t,
  unit u
where
  i.meter_id = m.id
  and m.unit_id = u.id
  and m.customer_id = c.id
  and m.tariff_id = t.id
  and i.id = $P{invoiceId}]]>
	</queryString>
	<field name="invoice_id" class="java.lang.Long"/>
	<field name="customer_code" class="java.lang.String"/>
	<field name="invoice_number" class="java.lang.String"/>
	<field name="serial" class="java.lang.String"/>
	<field name="tariff_name" class="java.lang.String"/>
	<field name="counsumption_month" class="java.sql.Timestamp"/>
	<field name="due_date" class="java.sql.Timestamp"/>
	<field name="total_amt" class="java.lang.Long"/>
	<field name="total_consumption" class="java.lang.Double"/>
	<field name="unit_no" class="java.lang.String"/>
