generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  schemas           = ["sim_system"]
}

// ===== Enums =====

enum ProjectStatus {
  active
  inactive
  @@map("project_status")
  @@schema("sim_system")
}

enum WaterDifferenceMode {
  billable
  report_only
  @@map("water_difference_mode")
  @@schema("sim_system")
}

enum NodeType {
  zone
  building
  floor
  unit
  @@map("node_type")
  @@schema("sim_system")
}

enum CustomerType {
  individual
  company
  tenant
  owner
  @@map("customer_type")
  @@schema("sim_system")
}

enum EntityStatus {
  active
  inactive
  @@map("entity_status")
  @@schema("sim_system")
}

enum MeterType {
  electricity
  water_main
  water_child
  @@map("meter_type")
  @@schema("sim_system")
}

enum MeterStatus {
  available
  assigned
  active
  offline
  faulty
  replaced
  terminated
  retired
  @@map("meter_status")
  @@schema("sim_system")
}

enum IpType {
  static
  dynamic
  @@map("ip_type")
  @@schema("sim_system")
}

enum SimStatus {
  available
  assigned
  active
  suspended
  old
  reusable
  retired
  @@map("sim_status")
  @@schema("sim_system")
}

enum AssignmentStatus {
  active
  ended
  @@map("assignment_status")
  @@schema("sim_system")
}

enum ReadingSource {
  manual
  import
  automatic
  @@map("reading_source")
  @@schema("sim_system")
}

enum ReadingStatus {
  valid
  pending_review
  estimated
  suspicious
  corrected
  rejected
  @@map("reading_status")
  @@schema("sim_system")
}

enum ReviewAction {
  approve
  reject
  correct
  @@map("review_action")
  @@schema("sim_system")
}

enum TariffStatus {
  draft
  active
  retired
  @@map("tariff_status")
  @@schema("sim_system")
}

enum BillingPeriodStatus {
  open
  in_review
  closed
  @@map("billing_period_status")
  @@schema("sim_system")
}

enum UtilityType {
  electricity
  water
  @@map("utility_type")
  @@schema("sim_system")
}

enum InvoiceStatus {
  draft
  pending_approval
  issued
  partially_paid
  paid
  overdue
  cancelled
  @@map("invoice_status")
  @@schema("sim_system")
}

enum AdjustmentType {
  credit
  debit
  @@map("adjustment_type")
  @@schema("sim_system")
}

enum PaymentMethod {
  cash
  bank_transfer
  card
  online
  cheque
  wallet
  @@map("payment_method")
  @@schema("sim_system")
}

enum PaymentStatus {
  pending
  confirmed
  reversed
  cancelled
  @@map("payment_status")
  @@schema("sim_system")
}

enum LedgerEntryType {
  invoice_charge
  adjustment_debit
  adjustment_credit
  payment_credit
  payment_reversal
  @@map("ledger_entry_type")
  @@schema("sim_system")
}

enum ReferenceType {
  invoice
  payment
  adjustment
  @@map("reference_type")
  @@schema("sim_system")
}

enum ReportJobStatus {
  pending
  running
  completed
  failed
  @@map("report_job_status")
  @@schema("sim_system")
}

enum ReportFormat {
  pdf
  excel
  csv
  @@map("report_format")
  @@schema("sim_system")
}

// ===== T013 — Core Org =====

model Project {
  id                        String              @id @default(uuid()) @map("id")
  code                      String              @unique @map("code")
  name                      String              @map("name")
  status                    ProjectStatus       @default(active) @map("status")
  taxEnabled                Boolean             @default(false) @map("tax_enabled")
  taxRate                   Decimal?            @map("tax_rate")
  readingThresholdProfileId String?             @map("reading_threshold_profile_id")
  waterDifferenceMode       WaterDifferenceMode @default(report_only) @map("water_difference_mode")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")
  createdBy                 String              @map("created_by")
  updatedBy                 String              @map("updated_by")
  locationNodes             LocationNode[]
  customers                 Customer[]

  @@map("projects")
  @@schema("sim_system")
}

model LocationNode {
  id                   String                    @id @default(uuid()) @map("id")
  projectId            String                    @map("project_id")
  parentId             String?                   @map("parent_id")
  nodeType             NodeType                  @map("node_type")
  code                 String                    @map("code")
  name                 String                    @map("name")
  status               EntityStatus              @default(active) @map("status")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  createdBy            String                    @map("created_by")
  updatedBy            String                    @map("updated_by")
  project              Project                   @relation(fields: [projectId], references: [id])
  parent               LocationNode?             @relation("LocationNodeHierarchy", fields: [parentId], references: [id])
  children             LocationNode[]            @relation("LocationNodeHierarchy")
  customerAssignments  CustomerUnitAssignment[]  @relation("AssignedUnit")

  @@unique([projectId, nodeType, code])
  @@index([parentId])
  @@map("location_nodes")
  @@schema("sim_system")
}

model Customer {
  id                     String                   @id @default(uuid()) @map("id")
  projectId              String                   @map("project_id")
  customerCode           String                   @map("customer_code")
  name                   String                   @map("name")
  phone                  String                   @map("phone")
  email                  String                   @map("email")
  customerType           CustomerType             @map("customer_type")
  nationalOrCommercialId String                   @map("national_or_commercial_id")
  status                 EntityStatus             @default(active) @map("status")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  createdBy              String                   @map("created_by")
  updatedBy              String                   @map("updated_by")
  project                Project                  @relation(fields: [projectId], references: [id])
  assignments            CustomerUnitAssignment[]

  @@unique([projectId, customerCode])
  @@map("customers")
  @@schema("sim_system")
}

model CustomerUnitAssignment {
  id         String       @id @default(uuid()) @map("id")
  customerId String       @map("customer_id")
  unitId     String       @map("unit_id")
  startAt    DateTime     @map("start_at")
  endAt      DateTime?    @map("end_at")
  reason     String       @map("reason")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  createdBy  String       @map("created_by")
  updatedBy  String       @map("updated_by")
  customer   Customer     @relation(fields: [customerId], references: [id])
  unit       LocationNode @relation("AssignedUnit", fields: [unitId], references: [id])

  @@map("customer_unit_assignments")
  @@schema("sim_system")
}

// ===== T014 — Meter & SIM =====

model Meter {
  id                String            @id @default(uuid()) @map("id")
  serialNumber      String            @unique @map("serial_number")
  meterType         MeterType         @map("meter_type")
  brand             String            @map("brand")
  model             String            @map("model")
  status            MeterStatus       @default(available) @map("status")
  installationDate  DateTime          @map("installation_date")
  activationDate    DateTime          @map("activation_date")
  terminationDate   DateTime?         @map("termination_date")
  projectId         String            @map("project_id")
  locationId        String?           @map("location_id")
  parentMainMeterId String?           @map("parent_main_meter_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  createdBy         String            @map("created_by")
  updatedBy         String            @map("updated_by")
  parentMainMeter   Meter?            @relation("MeterHierarchy", fields: [parentMainMeterId], references: [id])
  childMeters       Meter[]           @relation("MeterHierarchy")
  assignments       MeterAssignment[]
  simAssignments    SIMAssignment[]

  @@map("meters")
  @@schema("sim_system")
}

model SIMCard {
  id            String          @id @default(uuid()) @map("id")
  iccid         String          @unique @map("iccid")
  msisdn        String          @map("msisdn")
  provider      String          @map("provider")
  ipAddress     String          @map("ip_address")
  ipType        IpType          @map("ip_type")
  status        SimStatus       @default(available) @map("status")
  cooldownUntil DateTime?       @map("cooldown_until")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  createdBy     String          @map("created_by")
  updatedBy     String          @map("updated_by")
  assignments   SIMAssignment[]

  @@map("sim_cards")
  @@schema("sim_system")
}

model MeterAssignment {
  id           String           @id @default(uuid()) @map("id")
  meterId      String           @map("meter_id")
  customerId   String           @map("customer_id")
  unitId       String           @map("unit_id")
  projectId    String           @map("project_id")
  startAt      DateTime         @map("start_at")
  endAt        DateTime?        @map("end_at")
  changeReason String           @map("change_reason")
  status       AssignmentStatus @default(active) @map("status")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  createdBy    String           @map("created_by")
  updatedBy    String           @map("updated_by")
  meter        Meter            @relation(fields: [meterId], references: [id])

  @@map("meter_assignments")
  @@schema("sim_system")
}

model SIMAssignment {
  id           String           @id @default(uuid()) @map("id")
  simId        String           @map("sim_id")
  meterId      String           @map("meter_id")
  startAt      DateTime         @map("start_at")
  endAt        DateTime?        @map("end_at")
  changeReason String           @map("change_reason")
  status       AssignmentStatus @default(active) @map("status")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  createdBy    String           @map("created_by")
  updatedBy    String           @map("updated_by")
  sim          SIMCard          @relation(fields: [simId], references: [id])
  meter        Meter            @relation(fields: [meterId], references: [id])

  @@map("sim_assignments")
  @@schema("sim_system")
}

// ===== T015 — Readings, Tariffs, Billing Periods =====

model Reading {
  id                   String        @id @default(uuid()) @map("id")
  meterId              String        @map("meter_id")
  projectId            String        @map("project_id")
  customerIdSnapshot   String        @map("customer_id_snapshot")
  unitIdSnapshot       String        @map("unit_id_snapshot")
  readingValue         Decimal       @db.Decimal(12, 3) @map("reading_value")
  readingAt            DateTime      @map("reading_at")
  source               ReadingSource @map("source")
  previousReadingValue Decimal?      @db.Decimal(12, 3) @map("previous_reading_value")
  consumptionValue     Decimal?      @db.Decimal(12, 3) @map("consumption_value")
  status               ReadingStatus @default(pending_review) @map("status")
  rawPayload           Json?         @map("raw_payload")
  enteredBy            String        @map("entered_by")
  notes                String?       @map("notes")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  @@unique([meterId, readingAt, source])
  @@map("readings")
  @@schema("sim_system")
}

model ReadingReview {
  id           String       @id @default(uuid()) @map("id")
  readingId    String       @map("reading_id")
  reviewAction ReviewAction @map("review_action")
  reviewedBy   String       @map("reviewed_by")
  reviewedAt   DateTime     @map("reviewed_at")
  reason       String       @map("reason")

  @@map("reading_reviews")
  @@schema("sim_system")
}

model TariffPlan {
  id            String       @id @default(uuid()) @map("id")
  projectId     String       @map("project_id")
  meterType     MeterType    @map("meter_type")
  ratePerUnit   Decimal      @db.Decimal(12, 3) @map("rate_per_unit")
  currency      String       @map("currency")
  effectiveFrom DateTime     @map("effective_from")
  effectiveTo   DateTime?    @map("effective_to")
  status        TariffStatus @default(draft) @map("status")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  createdBy     String       @map("created_by")
  updatedBy     String       @map("updated_by")

  @@map("tariff_plans")
  @@schema("sim_system")
}

model BillingPeriod {
  id          String              @id @default(uuid()) @map("id")
  projectId   String              @map("project_id")
  periodCode  String              @map("period_code")
  startDate   DateTime            @map("start_date")
  endDate     DateTime            @map("end_date")
  status      BillingPeriodStatus @default(open) @map("status")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  createdBy   String              @map("created_by")
  updatedBy   String              @map("updated_by")

  @@unique([projectId, periodCode])
  @@map("billing_periods")
  @@schema("sim_system")
}

// ===== T016 — Invoices =====

model Invoice {
  id              String        @id @default(uuid()) @map("id")
  invoiceNumber   String        @unique @map("invoice_number")
  projectId       String        @map("project_id")
  customerId      String        @map("customer_id")
  unitId          String        @map("unit_id")
  meterId         String        @map("meter_id")
  utilityType     UtilityType   @map("utility_type")
  billingPeriodId String        @map("billing_period_id")
  status          InvoiceStatus @default(draft) @map("status")
  subtotalAmount  Decimal       @db.Decimal(12, 3) @map("subtotal_amount")
  taxAmount       Decimal       @db.Decimal(12, 3) @map("tax_amount")
  totalAmount     Decimal       @db.Decimal(12, 3) @map("total_amount")
  paidAmount      Decimal       @default(0) @db.Decimal(12, 3) @map("paid_amount")
  remainingAmount Decimal       @db.Decimal(12, 3) @map("remaining_amount")
  issuedAt        DateTime?     @map("issued_at")
  dueAt           DateTime?     @map("due_at")
  immutableAt     DateTime?     @map("immutable_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("invoices")
  @@schema("sim_system")
}

model InvoiceLine {
  id          String   @id @default(uuid()) @map("id")
  invoiceId   String   @map("invoice_id")
  readingId   String?  @map("reading_id")
  description String   @map("description")
  quantity    Decimal  @db.Decimal(12, 3) @map("quantity")
  unitPrice   Decimal  @db.Decimal(12, 3) @map("unit_price")
  lineAmount  Decimal  @db.Decimal(12, 3) @map("line_amount")

  @@map("invoice_lines")
  @@schema("sim_system")
}

model InvoiceAdjustment {
  id             String         @id @default(uuid()) @map("id")
  invoiceId      String         @map("invoice_id")
  adjustmentType AdjustmentType @map("adjustment_type")
  amount         Decimal        @db.Decimal(12, 3) @map("amount")
  reason         String         @map("reason")
  approvedBy     String?        @map("approved_by")
  createdBy      String         @map("created_by")

  @@map("invoice_adjustments")
  @@schema("sim_system")
}

// ===== T017 — Payments & Ledger =====

model Payment {
  id            String        @id @default(uuid()) @map("id")
  paymentNumber String        @unique @map("payment_number")
  projectId     String        @map("project_id")
  customerId    String        @map("customer_id")
  paymentDate   DateTime      @map("payment_date")
  method        PaymentMethod @map("method")
  amount        Decimal       @db.Decimal(12, 3) @map("amount")
  status        PaymentStatus @default(pending) @map("status")
  collectedBy   String        @map("collected_by")
  notes         String?       @map("notes")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("payments")
  @@schema("sim_system")
}

model PaymentAllocation {
  id              String  @id @default(uuid()) @map("id")
  paymentId       String  @map("payment_id")
  invoiceId       String  @map("invoice_id")
  allocatedAmount Decimal @db.Decimal(12, 3) @map("allocated_amount")
  allocationOrder Int     @map("allocation_order")

  @@map("payment_allocations")
  @@schema("sim_system")
}

model CustomerLedgerEntry {
  id             String          @id @default(uuid()) @map("id")
  customerId     String          @map("customer_id")
  projectId      String          @map("project_id")
  entryType      LedgerEntryType @map("entry_type")
  referenceType  ReferenceType   @map("reference_type")
  referenceId    String          @map("reference_id")
  amountDelta    Decimal         @db.Decimal(12, 3) @map("amount_delta")
  runningBalance Decimal         @db.Decimal(12, 3) @map("running_balance")
  entryAt        DateTime        @map("entry_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  @@map("customer_ledger_entries")
  @@schema("sim_system")
}

// ===== T008 — Idempotency =====

model IdempotencyRecord {
  id             String   @id @default(uuid()) @map("id")
  scopedKey      String   @unique @map("scoped_key")
  method         String   @map("method")
  route          String   @map("route")
  actor          String   @map("actor")
  requestHash    String?  @map("request_hash")
  responseBody   Json?    @map("response_body")
  responseStatus Int      @map("response_status")
  createdAt      DateTime @default(now()) @map("created_at")
  expiredAt      DateTime? @map("expired_at")

  @@map("idempotency_records")
  @@schema("sim_system")
}

// ===== T018 — Audit Logging & Reports =====

model AuditLog {
  id             String   @id @default(uuid()) @map("id")
  actorId        String   @map("actor_id")
  actorRole      String   @map("actor_role")
  action         String   @map("action")
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  beforeState    Json?    @map("before_state")
  afterState     Json?    @map("after_state")
  reason         String?  @map("reason")
  correlationId  String?  @map("correlation_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("audit_log")
  @@schema("sim_system")
  @@index([createdAt])
}

model ReportJob {
  id            String          @id @default(uuid()) @map("id")
  reportType    String          @map("report_type")
  status        ReportJobStatus @default(pending) @map("status")
  format        ReportFormat    @map("format")
  filters       Json?           @map("filters")
  fileUrl       String?         @map("file_url")
  requestedBy   String          @map("requested_by")
  errorMessage  String?         @map("error_message")
  createdAt     DateTime        @default(now()) @map("created_at")
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")

  @@map("report_jobs")
  @@schema("sim_system")
}
