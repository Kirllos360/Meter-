	<field name="to" class="java.lang.Integer"/>
	<field name="rate" class="java.lang.Integer"/>
	<field name="unit_type" class="java.lang.String"/>
	<field name="count" class="java.lang.Integer"/>
	<field name="cons_kwh" class="java.lang.Double"/>
	<field name="cons_egp" class="java.lang.Long"/>
