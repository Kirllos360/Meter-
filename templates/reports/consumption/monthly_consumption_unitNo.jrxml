	<field name="consumption_amount" class="java.lang.Long"/>
	<field name="name_ar" class="java.lang.String"/>
	<variable name="sum_total_amount" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{consumption_amount}]]></variableExpression>
	</variable>
