	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.1" value="title"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.3" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.4" value="pageFooter"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.keep.first.band.1" value="columnHeader"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.band.5" value="groupHeader"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="taqa_test"/>
	<parameter name="customer_id" class="java.lang.String"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="bill_cycle" class="java.lang.String"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  customer.id,
  customer.name_en,
  customer.name_ar,
  customer.phone,
  meter.serial,
  meter.type meter_type,
  monthly_reading.consumption_month,
(select top 1 monthly_reading_detail.reading_date from monthly_reading_detail where monthly_reading.id = monthly_reading_detail.monthly_reading_id) as reading_date,
(select top 1 monthly_reading_detail.start_value from monthly_reading_detail where monthly_reading.id = monthly_reading_detail.monthly_reading_id) as start_value,
(select top 1 monthly_reading_detail.current_value from monthly_reading_detail where monthly_reading.id = monthly_reading_detail.monthly_reading_id) as current_value,
  unit.unit_no AS unit_number,
  unit.city AS city,
  unit.additional_info,
  monthly_reading.total_amount /1000 'consumption_amount'
FROM
  meter INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
  INNER JOIN monthly_reading ON monthly_reading.meter_id = meter.id
WHERE
  1 = 1
  AND monthly_reading.status <> 'NEW'
  AND (customer.id = $P{customer_id} OR $P{customer_id} IS NULL)
  AND (lower(customer.name_en) like lower('%$P!{customer_name}%') OR $P{customer_name} IS NULL)
  AND (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  AND (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  AND (lower(unit.unit_no) like lower('%$P!{unit_number}%') OR $P{unit_number} IS NULL)
  AND (convert(date, monthly_reading.consumption_month) = $P{bill_cycle} OR $P{bill_cycle} IS NULL)
  and (unit.city = $P{village} OR $P{village} IS NULL)
  AND meter.project_id = $P{project_id}
ORDER BY
  customer.id,
  monthly_reading.consumption_month]]>
	</queryString>
	<field name="id" class="java.lang.Long"/>
	<field name="name_en" class="java.lang.String"/>
	<field name="phone" class="java.lang.String"/>
	<field name="serial" class="java.lang.String"/>
	<field name="meter_type" class="java.lang.String"/>
	<field name="consumption_month" class="java.sql.Timestamp"/>
	<field name="reading_date" class="java.sql.Timestamp"/>
	<field name="start_value" class="java.lang.Double"/>
