<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Alerts_Queue" pageWidth="1190" pageHeight="842" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="1150" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="3cd41ce5-13e0-47c4-a5fa-76d5f4b5d781">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.1" value="title"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.2" value="summary"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.3" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.4" value="pageFooter"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="start_date" class="java.lang.String">
		<defaultValueExpression><![CDATA["2013-08-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="end_date" class="java.lang.String">
		<defaultValueExpression><![CDATA["2013-08-31"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select * from (
  select
    created_by,
    created_date,
    'Bill Cycle' as scope,
    'Run billing cycle for ' + lower(service_id) + ' service and month ' + CAST(MONTH(consumption_month) as varchar) + '-' + CAST(YEAR(consumption_month) as varchar) + '' as action
  from
    billcycle_logs
  where
    1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Payment' as scope,
    'Collected an amount of ' + CAST(round(total_amt/1000,2) as varchar) + '' as action
  from
    payment
  where
    1 = 1
    and payment.status = 'ACTIVE'
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    last_modified_by,
    last_modified_date,
    'Payment' as scope,
    'Cancel a payment with an amount of ' + CAST(round(total_amt/1000,2) as varchar) + '' as action
  from
    payment
  where
    1 = 1
    and payment.status <> 'ACTIVE'
    and convert(DATE, last_modified_date) >= $P{start_date}
    and convert(DATE, last_modified_date) <= $P{end_date}
  union all
  select
    last_modified_by,
    last_modified_date,
    'Invoice' as scope,
    'Cancel an invoice with an amount of ' + CAST(round(total_amt/1000,2) as varchar) + '' as action
  from
    invoice
  where
    1 = 1
    and invoice.status <> 'ACTIVE'
    and convert(DATE, last_modified_date) >= $P{start_date}
    and convert(DATE, last_modified_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Customer' as scope,
    'Added a new customer ' + isnull(code,'') + '' as action
  from
    customer
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Settings' as scope,
    'Added a new project ' + isnull(project_title_en,'') + '' as action
  from
    adm_project
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Settings' as scope,
    'Added a new user ' + isnull(adm_user.[login],'') + '' as action
  from
    adm_user
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Settings' as scope,
    'Added a new friendly time or holiday ' as action
  from
    holiday
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Tariff' as scope,
    'Added a new tariff with name ' + name_en as action
  from
    tariff
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Tariff' as scope,
    'Added a new tariff charge with name ' + name_en as action
  from
    tariff_charges
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Settlement' as scope,
    'Added a new settlement with amount of ' + cast(round(total_amount/1000,2) as varchar) as action
  from
    meter_settlements
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
  union all
  select
    created_by,
    created_date,
    'Unit' as scope,
    'Added a new unit with number ' + unit_no as action
  from
    unit
  where
  1 = 1
    and convert(DATE, created_date) >= $P{start_date}
    and convert(DATE, created_date) <= $P{end_date}
) all_queries
order by
  all_queries.created_date desc]]>
	</queryString>
