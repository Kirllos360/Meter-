	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = meter.project_id) project_title,
  (select address_ar from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  meter.serial AS meter_serial,
  meter.name AS meter_name,
  meter.status AS meter_status,
  '' AS meter_model,
  meter.type AS meter_type
FROM
  meter
WHERE
  meter.status = 'NEW'
  AND (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  AND (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
ORDER BY
  meter.id]]>
	</queryString>
	<field name="project_title" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
	<field name="logo" class="java.lang.String"/>
	<field name="meter_serial" class="java.lang.String"/>
	<field name="meter_name" class="java.lang.String"/>
	<field name="meter_status" class="java.lang.String"/>
	<field name="meter_model" class="java.lang.String"/>
	<field name="meter_type" class="java.lang.String"/>
	<variable name="total_meters" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{meter_serial}]]></variableExpression>
	</variable>
