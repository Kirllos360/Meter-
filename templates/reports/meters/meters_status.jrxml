	<parameter name="meterType" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
  customer.id,
  customer.name_en,
  m.serial ,
  l.additional_info,
  isnull(m.balance,0) 'balance',
  (select isnull(sum(mr.total_amount),0) from monthly_reading mr where mr.meter_id =m.id and mr.invoice_id is null and mr.status <> 'NEW') 'not_invoiced',
  (select isnull(sum(i.open_amt),0) from invoice i where i.meter_id =m.id and i.status = 'ACTIVE') 'open_invoices',
  monthly_reading_detail.reading_date,
  monthly_reading_detail.start_value,
  monthly_reading_detail.current_value,
  monthly_reading.total_amount /1000 'consumption_amount' ,
  m.notifications_count ,
  m.relay_status
FROM
  meter m
  INNER JOIN customer ON customer.id = m.customer_id
  INNER JOIN unit l ON l.id = m.unit_id
  INNER JOIN monthly_reading ON monthly_reading.meter_id = m.id
  INNER JOIN monthly_reading_detail ON monthly_reading.id = monthly_reading_detail.monthly_reading_id
  INNER JOIN tariff_charges ON monthly_reading_detail.charge_id = tariff_charges.id
  INNER JOIN reading_type ON tariff_charges.reading_type_id = reading_type.id
WHERE
  1 = 1
  AND reading_type.is_default = 1
  AND m.notifications_count > 0 and m.notifications_count IS NOT NULL
  AND (m.type = $P{meterType} OR $P{meterType} IS NULL)]]>
	</queryString>
	<field name="id" class="java.lang.Long"/>
	<field name="name_en" class="java.lang.String"/>
	<field name="serial" class="java.lang.String"/>
	<field name="additional_info" class="java.lang.String"/>
	<field name="balance" class="java.lang.Long"/>
	<field name="not_invoiced" class="java.lang.Long"/>
	<field name="open_invoices" class="java.lang.Long"/>
	<field name="reading_date" class="java.sql.Timestamp"/>
	<field name="start_value" class="java.lang.Double"/>
	<field name="current_value" class="java.lang.Double"/>
	<field name="consumption_amount" class="java.lang.Long"/>
	<field name="notifications_count" class="java.lang.Integer"/>
	<field name="relay_status" class="java.lang.String"/>
	<variable name="sum_total_balance" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[($F{balance} - $F{not_invoiced} - $F{open_invoices}) /1000]]></variableExpression>
	</variable>
