	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.5" value="groupHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.group.5" value="Org Group"/>
	<property name="com.jaspersoft.studio.layout" value="com.jaspersoft.studio.editor.layout.FreeLayout"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="taqa_test"/>
	<style name="alternateStyle" mode="Transparent" backcolor="#FFFFFF" fontName="DejaVu Sans">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
			<style backcolor="#0000FF"/>
		</conditionalStyle>
	</style>
	<parameter name="project_id" class="java.lang.Integer"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="customer_id" class="java.lang.String"/>
	<parameter name="end_date" class="java.lang.String">
		<defaultValueExpression><![CDATA["2013-08-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="start_date" class="java.lang.String">
		<defaultValueExpression><![CDATA["2013-08-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="threshold_type" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    c.name_en AS client_name,
    c.mobile AS contact_number,
    c.email AS email_Address,
    c.code AS account_number,
    m.status,
    t.name_en AS tarrif,
	u.city AS region,
    u.additional_info AS additional_info,
	llz.name AS district,
	m.serial AS meter_number,
    p.img AS logo,
    (
    SELECT STRING_AGG(
        CAST(
            CAST(value AS FLOAT) / 1000.0
        AS VARCHAR), ', '
    )
    FROM STRING_SPLIT(
        CASE 
            WHEN $P{threshold_type} = 'Customer-based' THEN c.balance_limits
            WHEN $P{threshold_type} = 'Tariff-based' THEN t.balance_limits
        END,
        ','
    )
) AS threshold_level,
	    (
        ISNULL(m.balance, 0)
        - (
            SELECT ISNULL(SUM(mr2.total_amount), 0)
            FROM monthly_reading mr2
            WHERE mr2.meter_id = m.id AND mr2.invoice_id IS NULL
        )
        - (
            SELECT ISNULL(SUM(i.open_amt), 0)
            FROM invoice i
            WHERE i.meter_id = m.id AND i.status = 'ACTIVE'
        )
    ) AS available_credit,
    ROUND(SUM(
    CASE 
	    WHEN rt.category = 'IMPORT' 
	    THEN mrd.consumption_value 
	    ELSE 0 
	    END
	    ), 2) AS sumImport,
    ROUND(SUM(
    CASE 
	    WHEN rt.category = 'EXPORT' 
	    THEN mrd.consumption_value 
	    ELSE 0 
	    END
	    ), 2) AS sumExport

FROM 
    customer c
JOIN meter m ON m.customer_id = c.id
JOIN unit u ON m.unit_id =u.id
JOIN lk_location_zone llz ON u.location_zone_id =llz.id 
JOIN tariff t ON m.tariff_id = t.id
JOIN monthly_reading mr ON mr.meter_id = m.id
JOIN monthly_reading_detail mrd ON mrd.monthly_reading_id = mr.id
JOIN tariff_charges tc ON mrd.charge_id = tc.id
JOIN reading_type rt ON tc.reading_type_id = rt.id
JOIN adm_project p ON p.id = m.project_id

WHERE m.status ='ACTIVE'
	AND m.project_id = $P{project_id}
	AND(c.id = $P{customer_id} OR $P{customer_id} IS NULL)
	AND (c.name_en = $P{customer_name} OR $P{customer_name} IS NULL)
	AND (
	    ($P{start_date} IS NULL OR $P{end_date} IS NULL)
	    OR CONVERT(DATE, mr.consumption_month) BETWEEN $P{start_date} AND $P{end_date}
	)
	GROUP BY
    c.name_en, c.mobile, c.email, m.status, t.name_en, t.status,u.city,u.additional_info,llz.name,
    c.balance_limits,m.balance,m.id,c.code,p.img,m.serial,t.balance_limits
 HAVING 
    COUNT(
    	CASE 
    	WHEN rt.category = 'IMPORT' 
    	THEN 1 END ) > 0
	AND COUNT(
		CASE 
		WHEN rt.category = 'EXPORT' 
		THEN 1 END ) > 0]]>
	</queryString>
