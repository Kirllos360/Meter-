	<style name="alternateStyle" mode="Transparent" backcolor="#FFFFFF" fontName="DejaVu Sans">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
			<style backcolor="#0000FF"/>
		</conditionalStyle>
	</style>
	<parameter name="startDate" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="endDate" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="unitNumber" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="meterType" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
  c.id,
  c.name_ar,
  c.name_en,
  c.status,
  m.payment_type 'customer_type',
  m.relay_status relay,
  t.name_en tariff,
  m.serial,
  m.[type] 'meter_type',
  m.activation_date,
  l.unit_no,
  l.additional_info,
  '' as address_en,
  l.city,
  m.last_reading_date,
  isnull(m.balance,0) 'balance',
  (select isnull(sum(mr.total_amount),0) from monthly_reading mr where mr.meter_id =m.id and mr.invoice_id is null and mr.status <> 'NEW') 'not_invoiced',
  (select isnull(sum(i.open_amt),0) from invoice i where i.meter_id =m.id and i.status = 'ACTIVE') 'open_invoices'
from
  customer c,
  meter m,
  unit l,
  tariff t
where
  c.id = m.customer_id
  and m.unit_id = l.id
  and m.tariff_id = t.id
  and m.activation_date BETWEEN $P{startDate} AND $P{endDate}
  and (l.unit_no = $P{unitNumber}  OR $P{unitNumber} IS NULL)
  and (m.type = $P{meterType} OR $P{meterType} IS NULL)]]>
	</queryString>
	<field name="id" class="java.lang.Long"/>
	<field name="name_ar" class="java.lang.String"/>
	<field name="name_en" class="java.lang.String"/>
	<field name="status" class="java.lang.String"/>
	<field name="customer_type" class="java.lang.String"/>
	<field name="relay" class="java.lang.String"/>
	<field name="tariff" class="java.lang.String"/>
	<field name="serial" class="java.lang.String"/>
	<field name="meter_type" class="java.lang.String"/>
	<field name="activation_date" class="java.sql.Timestamp"/>
	<field name="unit_no" class="java.lang.String"/>
	<field name="additional_info" class="java.lang.String"/>
	<field name="address_en" class="java.lang.String"/>
	<field name="city" class="java.lang.String"/>
	<field name="last_reading_date" class="java.sql.Timestamp"/>
	<field name="balance" class="java.lang.Long"/>
	<field name="not_invoiced" class="java.lang.Long"/>
	<field name="open_invoices" class="java.lang.Long"/>
	<variable name="sum_total_balance" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[($F{balance} - $F{not_invoiced} - $F{open_invoices}) /1000]]></variableExpression>
	</variable>
