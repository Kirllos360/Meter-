	<parameter name="customer_id" class="java.lang.String"/>
	<parameter name="start_date" class="java.lang.String"/>
	<parameter name="end_date" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[select
  customer.id AS "customer_code",
  customer.name_en AS "customer_name",
  customer.name_ar AS "customer_name_ar",
  unit.unit_no AS "unit_no",
  notifications_history.mobile_number AS "mobile",
  notifications_history.email AS "email",
  meter.serial AS "meter_serial",
  notifications_history.sent_date AS "sent_date",
  notifications_history.subject AS "subject" ,
  notifications_history.sent_status AS "status" ,
  notifications_history.mode AS "notification_mode",
  meter.balance -
  (
    SELECT ISNULL(SUM(invoice.open_amt),0)
    FROM invoice
	WHERE invoice.meter_id = meter.id
  ) -
  (
  SELECT ISNULL(SUM(monthly_reading.total_amount),0)
  FROM monthly_reading
  WHERE monthly_reading.meter_id = meter.id and monthly_reading.invoice_id is null
  ) as balance
FROM
  meter INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
  INNER JOIN notifications_history ON notifications_history.meter_id = meter.id
WHERE
  1 = 1
  AND (customer.id = $P{customer_id} OR $P{customer_id} IS NULL)
  AND (notifications_history.sent_date BETWEEN $P{start_date} AND $P{end_date})
  AND meter.project_id = $P{project_id}]]>
	</queryString>
