	<parameter name="start_date" class="java.lang.String"/>
	<parameter name="end_date" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[select
  (select img from adm_project where id = m.project_id) logo,
  m.type,
  m.serial,
  c.name_ar,
  c.name_en,
  st.name,
  ms.total_amount,
  ms.per_month_amount,
  ms.number_of_months,
  ms.paid_amount,
  u.unit_no,
  (ms.total_amount - ms.paid_amount ) as remaining_amount
from
  meter m , customer c , meter_settlements ms,settlement_type st,unit u
where
  ms.meter_id = m.id
  and m.unit_id=u.id
  and m.customer_id = c.id
  and ms.settlement_type_id = st.id
  and ms.start_date between $P{start_date} and $P{end_date}
  and (m.type = $P{meter_type} OR $P{meter_type} IS NULL)
  and (m.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  and m.project_id = $P{project_id}
  order by m.serial]]>
	</queryString>
