	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.2" value="summary"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.3" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.4" value="pageFooter"/>
	<style name="style1" isDefault="true" mode="Opaque" backcolor="#FFFFFF" fill="Solid">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></conditionExpression>
			<style backcolor="#CCCCCC"/>
		</conditionalStyle>
	</style>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="consumption_month" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
	c.name_en,c.email
	,m.serial,
	l.address_en ,l.unit_no,mr.reading_date,$P{consumption_month} as consumption_month_value,
	mr.start_value , mr.current_value, (mr.current_value - mr.start_value) as current_consumption
	from
	monthly_reading mr,
	meter m,
	unit l,
	customer c,
	tariff_charges tc
	where mr.meter_id = m.id
	and m.unit_id = l.id
	and m.customer_id = c.id
          and ((m.type = $P{meter_type} OR $P{meter_type} IS NULL))
	and mr.consumption_month = $P{consumption_month}
    and mr.reading_date < DATEADD(month, 1, $P{consumption_month})
	and mr.status = 'PROCESSED'
	and tc.tariff_id = m.tariff_id
	and tc.charge_group = 'CONSUMPTION'
    and tc.name in('Consumption','Cosnumption')
	and mr.tariff_charge_name in('Consumption','Cosnumption')]]>
	</queryString>
	<field name="name_en" class="java.lang.String"/>
	<field name="email" class="java.lang.String"/>
	<field name="serial" class="java.lang.String"/>
	<field name="address_en" class="java.lang.String"/>
	<field name="unit_no" class="java.lang.String"/>
	<field name="reading_date" class="java.sql.Timestamp"/>
	<field name="consumption_month_value" class="java.lang.String"/>
	<field name="start_value" class="java.lang.Double"/>
	<field name="current_value" class="java.lang.Double"/>
	<field name="current_consumption" class="java.lang.Double"/>
