<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="missing_readings" pageWidth="953" pageHeight="842" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="913" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="3cd41ce5-13e0-47c4-a5fa-76d5f4b5d781">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.1" value="title"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.2" value="summary"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.3" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.4" value="pageFooter"/>
	<parameter name="consumption_month" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
  (select project_title_ar from adm_project where id = x.project_id) project_title,
  (select address_ar from adm_project where id = x.project_id) address,
  (select img from adm_project where id = x.project_id) logo,
  x.name_ar,
  x.unit_no,
  x.additional_info,
  x.serial,
  x.type,
  x.consumption_month,
  x.last_reading_date
from (
    select
      m.project_id,
      c.name_ar,
      l.unit_no,
      l.additional_info,
      m.serial,
      m.type,
      $P{consumption_month} as consumption_month,
      m.last_reading_date
    from
      meter m,
      unit l,
      customer c
    where
      m.status = 'ACTIVE' and m.id not in (select distinct meter_id from monthly_reading where consumption_month = $P{consumption_month})
      and (m.[type] = $P{meter_type} OR $P{meter_type} IS NULL)
      and m.customer_id = c.id
      and m.unit_id = l.id
    group by
      m.project_id,
      c.name_ar,
      l.unit_no,
      l.additional_info,
      m.serial,
      m.type,
      m.last_reading_date
) x
order by
  x.[type]]]>
	</queryString>
