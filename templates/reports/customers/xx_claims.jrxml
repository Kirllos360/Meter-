	<subDataset name="Table Dataset 1" uuid="d86bc65c-95b0-432d-a5dd-02f8ac250074"/>
	<parameter name="database_type" class="java.lang.String">
		<defaultValueExpression><![CDATA["SQL"]]></defaultValueExpression>
	</parameter>
	<parameter name="organization_ids" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="organization_ids_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{organization_ids} == null  ? "1=1" : "Organization_Portal.organizationid in (" + $P{organization_ids} + ")"]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_code_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{customer_code} == null  ? "1=1" : "lower(customer.customer_code) like  lower('%" + $P{customer_code} + "%')"]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_name_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{customer_name} == null  ? "1=1" : ($P{database_type} == "ORCL" ? "lower(customer.customer_name) like lower('%" + $P{customer_name} + "%')" : "lower(customer.customer_name) like lower(N'%" + $P{customer_name} + "%')")]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_serial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_serial_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{meter_serial} == null  ? "1=1" : "meters.meter_serial like '%" + $P{meter_serial} + "%'"]]></defaultValueExpression>
	</parameter>
	<parameter name="location_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="location_name_where" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{location_name} == null  ? "1=1" : ($P{database_type} == "ORCL" ? "lower(location.full_location_name) like lower('%" + $P{location_name} + "%')" : "lower(location.full_location_name) like lower(N'%" + $P{location_name} + "%')")]]></defaultValueExpression>
	</parameter>
	<parameter name="date_start" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="date_end" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SERVICE_ID" class="java.lang.String"/>
	<parameter name="SERVICE_ID_WHERE" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{SERVICE_ID} == null ? "1=1" : "billing_acct_serv_meter.service_id=" + $P{SERVICE_ID}]]></defaultValueExpression>
	</parameter>
	<parameter name="PARENT_LOCATION_ID" class="java.lang.String"/>
	<parameter name="PARENT_LOCATION_ID_WHERE" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{PARENT_LOCATION_ID}== null ? "1=1" :
 "(plocation.location_id = " + $P{PARENT_LOCATION_ID}
+"or plocation.parent_location_id ="  + $P{PARENT_LOCATION_ID}
+"or pplocation.location_id ="  + $P{PARENT_LOCATION_ID}
+"or pplocation.parent_location_id ="  + $P{PARENT_LOCATION_ID}+")"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
  billing_account.balance/100 balance,
  billing_account.billing_account_id BILLING_ACCOUNT_ID,
  customer.customer_code CUSTOMER_CODE,
  customer.customer_name CUSTOMER_NAME,
  billing_account.code CODE,
  billing_account.name,
  isnull(total_consumption.commulative_rudr,0)/100  CONS_AMOUNT,
  isnull(total_consumption.commulative_cons,0) CONS_VALUE,
  (isnull(total_payements.paid_total, 0))/100 PAID,
  (isnull(total_invoices.invoice_total, 0))/100 INVOICE,
  (isnull(total_invoices.invoices_total_paid, 0))/100 total_paid_invoices,
       location.location_name as 'unitName',
plocation.location_name as 'villageName',
pplocation.location_name 'projectName',
  billing_acct_serv_meter.service_id,
  meters.meter_serial METER_SERIAL,
  Organization_Portal.name ORG_NAME,
  cm.contract_date,
  cm.activation_date,billing_account.initial_balance/100 initial_balance
FROM

   billing_account
INNER JOIN billing_acct_serv_meter ON billing_acct_serv_meter.billing_account_id = billing_account.billing_account_id
 INNER JOIN meters ON   billing_acct_serv_meter.meter_id = meters.meter_id
inner join customer_meters cm on cm.meter_id=meters.meter_id
INNER JOIN location on meters.location_id =location.location_id
  INNER JOIN location plocation on location.parent_location_id = plocation.location_id
  INNER JOIN location pplocation on plocation.parent_location_id = pplocation.location_id
  INNER JOIN customer ON customer.customer_id=billing_account.customer_id
  INNER JOIN Organization_Portal ON customer.organization_id = Organization_Portal.organizationId
  LEFT JOIN (
    select billing_account_id, sum(meter_last_usage_values.last_udr_hourly_value - meter_last_usage_values.last_udr_value) as commulative_cons, sum(commulative_rudr) as commulative_rudr
    from meter_last_usage_values
	inner join customer_meters as c on c.meter_id = meter_last_usage_values.meter_id
    where meter_last_usage_values.bill_cycle_start_date > EOMONTH(c.activation_date)
    and cast (meter_last_usage_values.bill_cycle_end_date as date)<=cast($P{date_end} as date)
    and cast (meter_last_usage_values.bill_cycle_start_date as date)>=cast($P{date_start} as date)
    and meter_last_usage_values.invoice_id is not null
group by meter_last_usage_values.billing_account_id

  ) total_consumption
  ON total_consumption.billing_account_id=billing_account.billing_account_id

  LEFT OUTER JOIN
  (
    select SUM((isnull(payment_details.advance_amount,0) + isnull(payment_details.invoice_amount,0))) as paid_total, payment_details.billing_account_id
    from payments, payment_details
    where payments.payment_id = payment_details.payment_id
    group by payment_details.billing_account_id
  ) total_payements
  ON total_payements.billing_account_id=billing_account.billing_account_id
  LEFT OUTER JOIN
  (
    select SUM(isnull(invoice.total_amount,0)) as invoice_total, invoice.billing_account_id,
    SUM(isnull(invoice.paid_amount,0)) as invoices_total_paid
    from invoice
	inner join billcycle_log on billcycle_log.billcycle_log_id = invoice.billcycle_log_id
	inner join billing_acct_serv_meter as b on b.billing_account_id = invoice.billing_account_id
	inner join customer_meters as c on c.meter_id = b.meter_id
	where
	billcycle_log.start_date > EOMONTH(c.activation_date)
	and cast (billcycle_log.end_date as date)<=cast($P{date_end} as date)
	and cast (billcycle_log.start_date as date)>=cast($P{date_start} as date)
	group by invoice.billing_account_id
  ) total_invoices
  ON billing_account.billing_account_id=total_invoices.billing_account_id
WHERE
1=1
and customer.customer_name not like 'cat%utl%'
and $P!{customer_code_where}
and $P!{location_name_where}
and $P!{customer_name_where}
and $P!{meter_serial_where}
and $P!{organization_ids_where}
and $P!{SERVICE_ID_WHERE}
and $P!{PARENT_LOCATION_ID_WHERE}
--and (isnull(total_invoices.invoices_total_paid, 0)  - isnull(total_invoices.invoice_total, 0))/100 < -0.5]]>
	</queryString>
