	<style name="alternateStyle" mode="Transparent" backcolor="#FFFFFF" fontName="DejaVu Sans">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
			<style backcolor="#0000FF"/>
		</conditionalStyle>
	</style>
	<parameter name="meter_serial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="date_start" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="date_end" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="unit_number" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_type" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = meter.project_id) project_title,
  (select address_ar from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  customer.code customer_code,
  customer.id customer_id,
  meter.id meter_id,
  customer.name_en customer_name,
  unit.unit_no as 'unit_no',
  meter.serial meter_serial,
  meter.type meter_service,
  meter.activation_date,
  meter.created_date,
  meter.initial_balance,
  meter.balance -
  (
    select ISNULL(SUM(invoice.open_amt),0)
    from invoice
    where invoice.status != 'DELETED' AND invoice.meter_id = meter.id
  ) -
  (
    select ISNULL(SUM(monthly_reading.total_amount),0)
    from monthly_reading
    where monthly_reading.meter_id = meter.id
	and monthly_reading.invoice_id is null
	and monthly_reading.status <> 'NEW'
  ) as current_balance,
  (
    select monthly_reading.total_cons
	from monthly_reading
	where meter.id = monthly_reading.meter_id
	and (monthly_reading.consumption_month BETWEEN $P{date_start} AND $P{date_end})
  ) cons_kwh,
  (
    select SUM(monthly_reading.total_amount)
	from monthly_reading
	where meter.id = monthly_reading.meter_id
	and monthly_reading.invoice_id is null
	and (monthly_reading.consumption_month BETWEEN $P{date_start} AND $P{date_end} )
  ) not_invoice_amt,
  (
    select SUM(invoice.total_amt)
	from invoice
	where meter.id = invoice.meter_id
	and (invoice.counsumption_month BETWEEN $P{date_start} AND $P{date_end} )
	and invoice.status = 'ACTIVE'
  ) as invoices_amt,
  (
    select SUM(payment.total_amt)
    from payment
    where meter.id = payment.meter_id
    and (payment.payment_date BETWEEN $P{date_start} AND $P{date_end} )
    and payment.status = 'ACTIVE'
  ) as payments_amt
FROM
  customer INNER JOIN meter ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
WHERE
  1 = 1
  and (unit.unit_no = $P{unit_number} OR $P{unit_number} IS NULL)
  and (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  and (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)]]>
	</queryString>
