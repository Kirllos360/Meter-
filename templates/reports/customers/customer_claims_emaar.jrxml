	</variable>
	<variable name="total_invoices_SUM" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{invoices_amt}]]></variableExpression>
	</variable>
	<variable name="total_payments_SUM" class="java.lang.Double" calculation="Sum">
