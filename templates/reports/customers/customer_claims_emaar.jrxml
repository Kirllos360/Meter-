	<field name="current_balance" class="java.lang.Long"/>
	<field name="cons_kwh" class="java.lang.Double"/>
	<field name="not_invoice_amt" class="java.lang.Long"/>
	<field name="invoices_amt" class="java.lang.Long"/>
	<field name="payments_amt" class="java.lang.Long"/>
