		<band height="20">
			<textField isStretchWithOverflow="true" pattern="#,##0.00" isBlankWhenNull="true">
				<reportElement mode="Transparent" x="1180" y="0" width="110" height="20" forecolor="#000000" backcolor="#FFFFFF" uuid="92bc5166-9a38-4702-b2ea-64afbbd804a8"/>
				<box leftPadding="2" rightPadding="2">
					<leftPen lineWidth="0.5"/>
					<rightPen lineWidth="0.5"/>
