	<parameter name="start_date" class="java.lang.String">
		<defaultValueExpression><![CDATA["2013-08-01"]]></defaultValueExpression>
	</parameter>
	<parameter name="end_date" class="java.lang.String">
		<defaultValueExpression><![CDATA["2013-08-31"]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="tariff_id" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = meter.project_id) project_title,
  (select address_ar from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  customer.id as customer_id,
  customer.name_en AS customer_name,
  customer.name_ar AS customer_name_ar,
  unit.unit_no AS unit_no,
  unit.city AS city,
  unit.additional_info,
  meter.serial AS meter_serial,
  monthly_reading.total_cons AS consumption_kwh,
  CAST (monthly_reading.total_amount as float) AS consumption_le,
  monthly_reading.consumption_month as consumption_month,
  (select top 1 monthly_reading_detail.reading_date from monthly_reading_detail where monthly_reading.id = monthly_reading_detail.monthly_reading_id) as reading_date,
  meter.type AS meter_type,
  tariff.name_en as tariff_name
FROM
  meter
  INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
  INNER JOIN monthly_reading ON monthly_reading.meter_id = meter.id
  INNER JOIN tariff on meter.tariff_id = tariff.id
WHERE
  1 = 1
  and monthly_reading.status <> 'NEW'
  and convert(date, monthly_reading.consumption_month) between $P{start_date} and $P{end_date}
  AND (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  AND (meter.tariff_id = $P{tariff_id} OR $P{tariff_id} IS NULL)
  AND (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  AND (unit.unit_no = $P{unit_number} OR $P{unit_number} IS NULL)
  and (unit.city = $P{village} OR $P{village} IS NULL)
  AND meter.project_id = $P{project_id}
ORDER BY
  customer.id,
  meter.id,
  monthly_reading.consumption_month]]>
	</queryString>
