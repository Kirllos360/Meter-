	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="bill_cycle" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  (select project_title_ar from adm_project where id = meter.project_id) project_title,
  (select address_ar from adm_project where id = meter.project_id) address,
  (select img from adm_project where id = meter.project_id) logo,
  invoice.number AS invoice_no,
  customer.id AS customer_id,
  invoice.id,
  customer.name_en AS customer_name,
   customer.name_ar AS name_ar,
   unit.additional_info,
  unit.unit_no AS unit_no,
  meter.[type] as meter_type,
  invoice.total_consumption AS total_consuption,
  invoice.meter_serial AS meter_serial,
  invoice.counsumption_month AS counsumption_month,
  invoice.open_amt AS open_amt,
  invoice.total_amt AS total_amt,
  (SELECT SUM(invoice_details.amount) FROM invoice_details WHERE invoice_details.name IN ('Admin Fees') AND invoice_details.invoice_id = invoice.id ) as "Rosom_esdar",
  (SELECT SUM(invoice_details.amount) FROM invoice_details WHERE invoice_details.name IN ('رسم إذاعة', 'رسم محافظه' ) AND invoice_details.invoice_id = invoice.id ) as "ROSOM",
  (SELECT SUM(invoice_details.amount) FROM invoice_details WHERE invoice_details.name IN ('تمغة إستهلاك', 'تمغة توريد - تعاقد') AND invoice_details.invoice_id = invoice.id ) as "Dam3'at",
  (SELECT SUM (invoice_details.amount) FROM invoice_details WHERE invoice_details.name IN ('Customer Service Fees') AND invoice_details.invoice_id = invoice.id ) as "customer_service"
FROM
  meter
INNER JOIN invoice ON invoice.meter_id = meter.id
INNER JOIN customer ON customer.id = meter.customer_id
INNER JOIN unit ON unit.id = meter.unit_id
WHERE
  1 = 1
  and (invoice.counsumption_month = $P{bill_cycle} OR $P{bill_cycle} IS NULL)
  and (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  and (meter.type like $P{meter_type} OR $P{meter_type} IS NULL)
  and (unit.unit_no = $P!{unit_number} OR $P{unit_number} IS NULL)
  and (unit.city like $P{village} OR $P{village} IS NULL)
  and invoice.status = 'ACTIVE'
  and meter.project_id = $P{project_id}
ORDER BY
  customer.id,
  meter.id,
  invoice.counsumption_month]]>
	</queryString>
