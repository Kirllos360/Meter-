	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="taqa_test"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="customer_id" class="java.lang.String"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="bill_cycle" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  invoice.id INVOICE_ID,
  invoice.number INVOICE_NUMBER,
  customer.name_en CUSTOMER_NAME,
  customer.name_ar,
  customer.phone P_PHONE,
  customer.mobile S_PHONE,
  invoice.total_amt TOTAL_AMOUNT,
  invoice.total_consumption CONSUMPTION,
  meter.serial METER_SERIAL,
  unit.unit_no ,
  unit.additional_info,
  unit.city ,
  invoice.counsumption_month BC_DATE,
  meter.balance / 1000 -
  (
    select SUM(invoice.open_amt / 1000)
	from invoice WHERE invoice.meter_id = meter.id
  ) - (
	select SUM(monthly_reading.total_amount / 1000)
	from monthly_reading WHERE monthly_reading.meter_id = meter.id
	and monthly_reading.invoice_id is null
	and status <> 'NEW'
  ) as BALANCE,
  0 RREVIOUS_R,
  0 CURRENT_R,
  meter.type METER_TYPE
FROM
  meter
  INNER JOIN customer ON customer.id = meter.customer_id
  INNER JOIN unit ON unit.id = meter.unit_id
  INNER JOIN invoice ON invoice.meter_id = meter.id
WHERE
  1 = 1
  AND invoice.status = 'ACTIVE'
  AND (customer.id = $P{customer_id} OR $P{customer_id} IS NULL)
  AND (lower(customer.name_en) = lower('%$P!{customer_name}%') OR $P{customer_name} IS NULL)
  AND (meter.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  AND (meter.type = $P{meter_type} OR $P{meter_type} IS NULL)
  AND (lower(unit.unit_no) like lower('%$P!{unit_number}%') OR $P{unit_number} IS NULL)
  AND (convert(date, invoice.counsumption_month) = $P{bill_cycle} OR $P{bill_cycle} IS NULL)
  AND meter.project_id = $P{project_id}
ORDER BY
  customer.id,
  meter.id,
  invoice.counsumption_month]]>
	</queryString>
	<field name="INVOICE_ID" class="java.lang.Long"/>
	<field name="INVOICE_NUMBER" class="java.lang.String"/>
	<field name="CUSTOMER_NAME" class="java.lang.String"/>
