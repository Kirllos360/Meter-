	<field name="CURRENT_R" class="java.lang.Integer"/>
	<field name="METER_TYPE" class="java.lang.String"/>
	<field name="name_ar" class="java.lang.String"/>
	<sortField name="METER_SERIAL"/>
	<variable name="TRANS_COUNT" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{INVOICE_NUMBER}]]></variableExpression>
	</variable>
	<variable name="sum_total_amount" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_AMOUNT}.doubleValue()/1000]]></variableExpression>
	</variable>
