	<parameter name="BILLING_ACCOUNT_ID" class="java.lang.Long">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="date_start" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="date_end" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="meter_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
 invoice.number invoice_number,
 invoice.counsumption_month invoice_date,
 invoice.total_amt total_amount,
 invoice.paid_amt paid_amount,
 invoice.open_amt open_amount,
 invoice.status
FROM
 invoice
WHERE
 invoice.meter_id = $P{meter_id}
 and invoice.counsumption_month BETWEEN $P{date_start} AND $P{date_end}]]>
	</queryString>
	<field name="invoice_number" class="java.lang.String"/>
	<field name="invoice_date" class="java.sql.Timestamp"/>
	<field name="total_amount" class="java.lang.Long"/>
	<field name="paid_amount" class="java.lang.Long"/>
	<field name="open_amount" class="java.lang.Long"/>
	<field name="status" class="java.lang.String"/>
