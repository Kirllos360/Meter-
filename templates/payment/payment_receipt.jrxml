	<subDataset name="payment reading details" uuid="ebf092ee-bc1c-4c8d-af50-0eda31e50d44">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="billing_new_iskra"/>
		<parameter name="paymentId" class="java.lang.Long">
			<parameterDescription><![CDATA[]]></parameterDescription>
			<defaultValueExpression><![CDATA[$P{paymentId}]]></defaultValueExpression>
		</parameter>
		<queryString language="SQL">
			<![CDATA[SELECT 
    p.reading_type_name,
    p.reading_value,
    p.reading_date,
CASE 
	  when r.[service_type] like 'ELECTRICITY%' then 'kWh'
	  when r.[service_type] like 'WATER%' then 'm³'
	  when r.[service_type]='SOLAR' then 'kWh'
	  else NULL 
  END AS unitEn,
  CASE 
	  when r.[service_type] like 'ELECTRICITY%' then N'ك.و.س'
	  when r.[service_type] like 'WATER%' then N'م³'
	  when r.[service_type]='SOLAR' then N'ك.و.س'
	  else NULL 
  END AS unitAr
FROM 
    payment_reading_details p
JOIN 
    reading_type r ON p.reading_type_name = r.reading_type_name
WHERE 
    p.payment_id = $P{paymentId}
    AND r.view_in_report = 1;]]>
		</queryString>
		<field name="reading_type_name" class="java.lang.String"/>
		<field name="reading_value" class="java.lang.Double"/>
		<field name="reading_date" class="java.sql.Timestamp"/>
		<field name="unitEn" class="java.lang.String"/>
		<field name="unitAr" class="java.lang.String"/>
	</subDataset>
	<parameter name="paymentId" class="java.lang.Long"/>
	<queryString language="SQL">
		<![CDATA[select
  (select project_title_ar from adm_project where id = m.project_id) project_title,
  (select project_title_en from adm_project where id = m.project_id) project_title_en,
  (select address_ar from adm_project where id = m.project_id) address,
  (select address_en from adm_project where id = m.project_id) address_en,
  (select license from adm_project where id = m.project_id) license,
  (select bank_details from adm_project where id = m.project_id) bank_details,
  (select img from adm_project where id = m.project_id) logo,
  (select signature from adm_project where id = m.project_id ) signature,
  p.id,
  p.status,
  c.id customer_id,
  c.commercial_name,
  m.project_id  project_id,
  c.tenant_name,
  l.unit_no,
  l.additional_info,
  c.name_ar,
  c.name_en,
--  SUBSTRING( ( SELECT ' - ' + name_ar AS [text()] FROM dbo.[contact_person] WHERE customer_id = p.customer_id FOR XML PATH ('') ), 2, 1000) names_ar,
--  SUBSTRING( ( SELECT ' - ' + name_en AS [text()] FROM dbo.[contact_person] WHERE customer_id = p.customer_id FOR XML PATH ('') ), 2, 1000) names_en,
  p.type,
  p.total_amt,
  p.receipt_no,
  p.payment_date,
  c.name_en,
  c.name_ar,
  m.serial,
  m.[type] meter_type,
  p.created_by,
  p.cheque_number,
  p.transfer_number,
  p.bank_name,
  p.balance_before,
  p.balance_after,
  p.last_reading_date,
  p.last_reading_value,
  p.payment_fees,
  p.settlement_amount,
    CASE 
	  when m.[type] like 'ELECTRICITY%' then 'kWh'
	  when m.[type] like 'WATER%' then 'm³'
	  when m.[type]='SOLAR' then 'kWh'
	  else NULL 
  END AS unitEn,
  CASE 
	  when m.[type] like 'ELECTRICITY%' then N'ك.و.س'
	  when m.[type] like 'WATER%' then N'م³'
	  when m.[type]='SOLAR' then N'ك.و.س'
	  else NULL 
  END AS unitAr
from
  payment p,
  customer c,
  meter m,
  unit l
where
  p.id = $P{paymentId}
  and p.customer_id = c.id
  and m.unit_id = l.id
  and m.customer_id = c.id
  and m.id = p.meter_id
  and p.contractual_request_id is null]]>
	</queryString>
