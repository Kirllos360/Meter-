		<variableExpression><![CDATA[$F{status}.equals("ACTIVE") && $F{payment_type}.equals("CHEQUE")
  ? $F{total_amt} : 0]]></variableExpression>
	</variable>
	<variable name="total_amt_trans" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{status}.equals("ACTIVE") && $F{payment_type}.equals("TRANSFER")
  ? $F{total_amt} : 0]]></variableExpression>
	</variable>
	<variable name="total_amt_SetAsPaid" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{status}.equals("ACTIVE") && $F{payment_type}.equals("SetAsPaid")   ? $F{total_amt} : 0]]></variableExpression>
	</variable>
