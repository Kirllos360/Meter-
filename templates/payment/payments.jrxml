	</variable>
	<variable name="total_amt_1" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{status}.equals("ACTIVE")
  ? $F{total_amt} : 0]]></variableExpression>
	</variable>
	<variable name="total_amt_2" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[!$F{status}.equals("ACTIVE") ? $F{total_amt} : 0]]></variableExpression>
	</variable>
	<variable name="total_amt_cash" class="java.lang.Long" calculation="Sum">
		<variableExpression><![CDATA[$F{status}.equals("ACTIVE") && $F{payment_type}.equals("CASH")
  ? $F{total_amt} : 0]]></variableExpression>
	</variable>
	<variable name="total_amt_visa" class="java.lang.Long" calculation="Sum">
