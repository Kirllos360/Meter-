	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="taqa_test"/>
	<parameter name="start_date" class="java.lang.String"/>
	<parameter name="end_date" class="java.lang.String"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="meter_serial" class="java.lang.String"/>
	<parameter name="meter_type" class="java.lang.String"/>
	<parameter name="unit_number" class="java.lang.String"/>
	<parameter name="bill-cycle" class="java.lang.String"/>
	<parameter name="payment_type" class="java.lang.String"/>
	<parameter name="village" class="java.lang.String"/>
	<parameter name="project_id" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[select
  (select project_title_ar from adm_project where id = m.project_id) project_title,
  (select address_ar from adm_project where id = m.project_id) address,
  (select img from adm_project where id = m.project_id) logo,
  p.id,
  p.receipt_no,
  p.status,
  p.payment_date,
  c.name_ar,
  c.name_en,
  l.unit_no,
  l.additional_info,
  '' as address_en,
  l.city,
  pc.name 'center_name',
  p.total_amt,
  p.[type] 'payment_type',
  m.serial,
  m.type,
  p.created_by,
  1 as payment_channel_id,
  p.auth_code,
  p.ref_number,
  p.cheque_date,
  p.cheque_number,
  p.bank_name,
  p.transfer_date,
  p.bank_account,
  p.bank_name,
  p.reason,
  ba.account_name our_bank_name,
  ba.account_number our_bank_number
from
  payment p
  left outer join payment_center pc on pc.id = p.payment_center_id
  left outer join lk_bank_account ba on ba.id = p.bank_account_id,
  customer c,
  meter m,
  unit l
where
  p.customer_id = c.id
  and m.customer_id = c.id
  and p.meter_id = m.id
  and l.id = m.unit_id
  and convert(date, p.payment_date) >= $P{start_date}
  and convert(date, p.payment_date) <= $P{end_date}
  and (lower(c.name_en) like lower('%$P!{customer_name}%') OR $P{customer_name} IS NULL )
  and (p.[type] = $P{payment_type} OR $P{payment_type} IS NULL)
  and (m.serial = $P{meter_serial} OR $P{meter_serial} IS NULL)
  and (lower(m.type) = lower($P{meter_type}) OR $P{meter_type} IS NULL)
  and (lower(l.unit_no) like lower('%$P!{unit_number}%') OR $P{unit_number} IS NULL)
  and (lower(l.city) = lower($P{village}) OR $P{village} IS NULL)
  and m.project_id = $P{project_id}
order by p.id desc]]>
	</queryString>
