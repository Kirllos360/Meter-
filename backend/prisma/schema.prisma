generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  schemas           = ["sim_system"]
}

model AuditLog {
  id             String   @id @default(uuid()) @map("id")
  actorId        String   @map("actor_id")
  actorRole      String   @map("actor_role")
  action         String   @map("action")
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  beforeState    Json?    @map("before_state")
  afterState     Json?    @map("after_state")
  reason         String?  @map("reason")
  correlationId  String?  @map("correlation_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("audit_log")
  @@schema("sim_system")
}

enum UtilityType {
  electricity
  water

  @@map("utility_type")
  @@schema("sim_system")
}

enum InvoiceStatus {
  draft
  pending_approval
  issued
  partially_paid
  paid
  overdue
  cancelled

  @@map("invoice_status")
  @@schema("sim_system")
}

enum AdjustmentType {
  credit
  debit

  @@map("adjustment_type")
  @@schema("sim_system")
}

model Invoice {
  id               String        @id @default(uuid()) @map("id")
  invoiceNumber    String        @unique @map("invoice_number")
  projectId        String        @map("project_id")
  customerId       String        @map("customer_id")
  unitId           String        @map("unit_id")
  meterId          String        @map("meter_id")
  utilityType      UtilityType   @map("utility_type")
  billingPeriodId  String        @map("billing_period_id")
  status           InvoiceStatus @default(draft) @map("status")
  subtotalAmount   Decimal       @db.Decimal(12, 3) @map("subtotal_amount")
  taxAmount        Decimal       @db.Decimal(12, 3) @map("tax_amount")
  totalAmount      Decimal       @db.Decimal(12, 3) @map("total_amount")
  paidAmount       Decimal       @default(0) @db.Decimal(12, 3) @map("paid_amount")
  remainingAmount  Decimal       @db.Decimal(12, 3) @map("remaining_amount")
  issuedAt         DateTime?     @map("issued_at")
  dueAt            DateTime?     @map("due_at")
  immutableAt      DateTime?     @map("immutable_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@map("invoices")
  @@schema("sim_system")
}

model InvoiceLine {
  id          String   @id @default(uuid()) @map("id")
  invoiceId   String   @map("invoice_id")
  readingId   String?  @map("reading_id")
  description String   @map("description")
  quantity    Decimal  @db.Decimal(12, 3) @map("quantity")
  unitPrice   Decimal  @db.Decimal(12, 3) @map("unit_price")
  lineAmount  Decimal  @db.Decimal(12, 3) @map("line_amount")

  @@map("invoice_lines")
  @@schema("sim_system")
}

model InvoiceAdjustment {
  id             String         @id @default(uuid()) @map("id")
  invoiceId      String         @map("invoice_id")
  adjustmentType AdjustmentType @map("adjustment_type")
  amount         Decimal        @db.Decimal(12, 3) @map("amount")
  reason         String         @map("reason")
  approvedBy     String?        @map("approved_by")
  createdBy      String         @map("created_by")

  @@map("invoice_adjustments")
  @@schema("sim_system")
}
