// ===== Area Schema Models (v2.0.0) =====
// ===== Domain: Customer & Meter =====

model AreaCustomer {
  id                 String            @id @default(uuid()) @map("id")
  customerCode       String            @unique @map("customer_code")
  fullName           String            @map("full_name")
  phoneNumber        String?           @map("phone_number")
  email              String?           @map("email")
  nationalId         String?           @map("national_id")
  address            String?           @map("address")
  unitId             String?           @map("unit_id")
  unitTypeId         String?           @map("unit_type_id")
  groupId            String?           @map("group_id")
  status             AreaCustomerStatus @default(active) @map("status")
  currentBalance     Decimal           @default(0) @db.Decimal(14, 3) @map("current_balance")
  creditLimit        Decimal           @default(0) @db.Decimal(14, 3) @map("credit_limit")
  isExemptFromLateFee Boolean          @default(false) @map("is_exempt_from_late_fee")
  notes              String?           @map("notes")
  createdBy          String            @map("created_by")
  updatedBy          String            @map("updated_by")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  customerMeters             AreaCustomerMeter[]
  invoices                   AreaInvoiceDetail[]
  transactions               AreaTransaction[]
  ledgerEntries              AreaCustomerLedgerEntry[]
  alerts                     AreaAlert[]
  chatMessages               AreaChatMessage[]
  tasks                      AreaTask[]
  troubleTickets             AreaTroubleTicket[]
  waterBalances              AreaWaterBalance[]
  solarWalletTransactions    AreaSolarWalletTransaction[]
  chilledWaterSettlements    AreaChilledWaterSettlement[]
  journalEntries             AreaJournalEntry[]
  paymentPlans               AreaPaymentPlan[]
  lateFees                   AreaLateFee[]
  deposits                   AreaDeposit[]
  refunds                    AreaRefund[]
  disputes                   AreaDispute[]
  contracts                  AreaContract[]
  subscriptions              AreaSubscription[]
  collectionActions          AreaCollectionAction[]
  meterTransfersAsFrom       AreaMeterTransfer[]   @relation("MeterTransferFrom")
  meterTransfersAsTo         AreaMeterTransfer[]   @relation("MeterTransferTo")

  @@index([status])
  @@index([unitId])
  @@index([currentBalance])
  @@map("customers")
  @@schema("area")
}

model AreaCustomerMeter {
  id                String          @id @default(uuid()) @map("id")
  customerId        String          @map("customer_id")
  meterNumber       String          @unique @map("meter_number")
  meterType         AreaMeterType   @map("meter_type")
  model             String?         @map("model")
  status            String          @default("installed") @map("status")
  installationDate  DateTime?       @map("installation_date")
  lastReadingDate   DateTime?       @map("last_reading_date")
  lastReadingValue  Decimal?        @db.Decimal(18, 4) @map("last_reading_value")
  latitude          Decimal?        @db.Decimal(9, 6) @map("latitude")
  longitude         Decimal?        @db.Decimal(9, 6) @map("longitude")
  isSmartMeter      Boolean         @default(false) @map("is_smart_meter")
  firmwareVersion   String?         @map("firmware_version")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  customer          AreaCustomer    @relation(fields: [customerId], references: [id])

  metersReadings        AreaMeterReading[]
  simAssignments        AreaSIMAssignment[]
  meterStatusLogs       AreaMeterStatusLog[]
  calibrations          AreaMeterCalibration[]
  transfers             AreaMeterTransfer[]
  usageSummaries        AreaUsageSummary[]
  workOrders            AreaWorkOrder[]

  @@index([customerId])
  @@index([status])
  @@map("customer_meters")
  @@schema("area")
}

model AreaMeterReading {
  id              BigInt            @id @default(autoincrement()) @map("id")
  customerMeterId String            @map("customer_meter_id")
  readingValue    Decimal           @db.Decimal(18, 4) @map("reading_value")
  consumption     Decimal?          @db.Decimal(18, 4) @map("consumption")
  readingDate     DateTime          @map("reading_date")
  source          AreaReadingSource @map("source")
  status          AreaReadingStatus @default(pending) @map("status")
  isEstimated     Boolean           @default(false) @map("is_estimated")
  readBy          String?           @map("read_by")
  notes           String?           @map("notes")
  createdAt       DateTime          @default(now()) @map("created_at")
  customerMeter   AreaCustomerMeter @relation(fields: [customerMeterId], references: [id])

  reviews AreaReadingReview[]

  @@index([customerMeterId])
  @@index([readingDate])
  @@index([status])
  @@index([source])
  @@map("meter_readings")
  @@schema("area")
}

model AreaSIMCard {
