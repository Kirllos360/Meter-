  newValue    String?      @map("new_value")
  performedBy String       @map("performed_by")
  performedAt DateTime     @default(now()) @map("performed_at")
  cycle       BillingCycle @relation(fields: [cycleId], references: [id])

  @@index([cycleId])
  @@map("billing_cycle_audits")
  @@schema("features")
}

// Domain 6: Document Engine

model DocumentTemplate {
  id              String     @id @default(uuid()) @map("id")
  templateCode    String     @unique @map("template_code")
  templateName    String     @map("template_name")
  documentType    String     @map("document_type")
  category        String     @map("category")
  content         String     @map("content")
  variables       Json?      @map("variables")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  createdBy       String     @map("created_by")
  updatedBy       String     @map("updated_by")

  versions        TemplateVersion[]
  documents       GeneratedDocument[]

  @@map("document_templates")
  @@schema("features")
}

model TemplateVersion {
  id              String           @id @default(uuid()) @map("id")
  templateId      String           @map("template_id")
  versionNo       Int              @map("version_no")
  content         String           @map("content")
  changeLog       String           @map("change_log")
  approvedBy      String            @map("approved_by")
  approvedAt      DateTime         @map("approved_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  template        DocumentTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, versionNo])
  @@map("template_versions")
  @@schema("features")
}

model GeneratedDocument {
  id              String           @id @default(uuid()) @map("id")
  templateId      String           @map("template_id")
  documentNumber  String           @unique @map("document_number")
  referenceType   String           @map("reference_type")
  referenceId     String           @map("reference_id")
  status          DocumentStatus   @default(DRAFT) @map("status")
  content         String           @map("content")
  renderedHtml    String?          @map("rendered_html")
  fileUrl         String?          @map("file_url")
  fileSize        Int?             @map("file_size")
  generatedBy     String           @map("generated_by")
  generatedAt     DateTime         @default(now()) @map("generated_at")
  finalizedAt     DateTime?        @map("finalized_at")
  template        DocumentTemplate @relation(fields: [templateId], references: [id])

